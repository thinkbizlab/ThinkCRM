<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme.WorkCRM is a thin Material 3 shell; the real palette and
         typography live in DesignSystem/Theme.kt so they stay in lockstep
         with the iOS DesignSystem. -->
    <style name="Theme.WorkCRM" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
