{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/app.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/modules/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/styles.css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ],
  "crons": [
    {
      "path": "/api/v1/cron/weekly-digest",
      "schedule": "0 23 * * 0"
    },
    {
      "path": "/api/v1/cron/kpi-alert",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/v1/cron/trial-expiry",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/v1/cron/data-retention",
      "schedule": "15 0 * * *"
    },
    {
      "path": "/api/v1/cron/sync-rest-pull",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/v1/cron/sync-mysql-pull",
      "schedule": "* * * * *"
    }
  ]
}
