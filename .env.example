# ─── Core ────────────────────────────────────────────────────────────────────
# SQLite for development; use PostgreSQL in production (see H1 in review notes).
DATABASE_URL="file:./dev.db"
PORT=3000
NODE_ENV=development

# Must be a random string ≥ 32 chars in production. Never commit the real value.
JWT_SECRET="change-me-to-a-random-32-char-string"

# Public URL of this app — required for OAuth redirect URIs and email deep links.
# Example: https://app.thinkbizcrm.com  (no trailing slash)
APP_URL="https://app.thinkbizcrm.com"

# Base domain for tenant subdomains (e.g. "thinkbizcrm.com").
# When set, {slug}.thinkbizcrm.com resolves to the matching tenant automatically.
# Requires wildcard DNS (*.thinkbizcrm.com) pointing to this server + wildcard SSL.
BASE_DOMAIN="thinkbizcrm.com"

# ─── Cloudflare R2 Storage ───────────────────────────────────────────────────
# Required for avatar uploads, voice note audio, and visit attachments.
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="thinkcrm-assets"
# Signed URL expiry in seconds (default 900 = 15 min; max 3600).
R2_SIGNED_URL_EXPIRES_SECONDS=900
# Optional: public bucket URL (Cloudflare R2 → bucket → Settings → Public Development URL).
# Required for LINE check-in selfie photos to appear in group notifications.
# Example: https://pub-xxxx.r2.dev
R2_PUBLIC_URL=""

# ─── AI / Voice Notes ────────────────────────────────────────────────────────
# Required for voice note transcription (Whisper) and AI summary (Claude).
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Required for the map picker in visit and customer address forms.
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ─── OAuth Login — Microsoft 365 ─────────────────────────────────────────────
# Register an app in Azure AD (portal.azure.com → App registrations).
# Redirect URI to register: {APP_URL}/api/v1/auth/oauth/ms365/callback
# Required scopes: openid email profile User.Read
MS365_CLIENT_ID=""
MS365_CLIENT_SECRET=""
# Your Azure AD tenant ID, or "common" for multi-tenant.
MS365_TENANT_ID="common"

# ─── OAuth Login — Google ────────────────────────────────────────────────────
# Register an OAuth 2.0 client in Google Cloud Console.
# Redirect URI to register: {APP_URL}/api/v1/auth/oauth/google/callback
# Required scopes: openid email profile
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Stripe Billing ──────────────────────────────────────────────────────────
# Get from dashboard.stripe.com → Developers → API keys.
# Required to enable Checkout and Customer Portal.
STRIPE_SECRET_KEY="sk_test_..."
# Webhook secret from dashboard.stripe.com → Developers → Webhooks → Signing secret.
STRIPE_WEBHOOK_SECRET="whsec_..."
# Monthly price ID from dashboard.stripe.com → Products → (your plan) → Prices.
STRIPE_PRICE_ID="price_..."

# ─── Integration Credential Encryption (C6) ─────────────────────────────────
# AES-256-GCM key for encrypting integration secrets at rest (LINE tokens, Teams
# passwords, Slack tokens, SMTP passwords, Anthropic keys, etc.).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Optional in development; STRONGLY RECOMMENDED in production.
# WARNING: If you set this after data exists, run the app once to auto-migrate existing rows.
# WARNING: Do not change this key once set — existing credentials cannot be decrypted.
ENCRYPTION_KEY=""

# ─── System SMTP (Password Reset Fallback) ───────────────────────────────────
# Used for password-reset emails when the tenant has no EMAIL integration configured.
# If the tenant has its own EMAIL credential, that is used first; these are the fallback.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@example.com"

# ─── Apple Push Notifications (iOS App) ──────────────────────────────────────
# Required for sending push notifications to the iOS app.
# Generate a .p8 key file in Apple Developer → Keys → Apple Push Notifications service (APNs).
APNS_KEY_ID=""
APNS_TEAM_ID=""
APNS_BUNDLE_ID="com.yourcompany.thinkcrm"
# Path to the .p8 private key file (e.g. "./AuthKey_XXXXXXXXXX.p8").
APNS_KEY_PATH=""
# "development" for TestFlight/debug builds; "production" for App Store.
APNS_ENVIRONMENT="development"

# ─── Vercel Cron ─────────────────────────────────────────────────────────────
# Protects /api/v1/cron/* endpoints from unauthorized access.
# Auto-set by Vercel when cron jobs are configured. For non-Vercel deployments,
# generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=""

# ─── Audio Conversion ────────────────────────────────────────────────────────
# Path to ffmpeg binary used for voice note audio conversion.
# Defaults to "ffmpeg" (system PATH). Override if ffmpeg is not on PATH.
# FFMPEG_PATH="/usr/local/bin/ffmpeg"
