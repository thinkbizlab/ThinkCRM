DATABASE_URL="file:./dev.db"
PORT=3000
NODE_ENV=development
JWT_SECRET="thinkcrm-dev-secret-please-change"
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="thinkcrm-assets"
R2_SIGNED_URL_EXPIRES_SECONDS=900
# Optional: enable public bucket URL for LINE image delivery (Cloudflare R2 → bucket → Settings → Public Development URL)
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
ANTHROPIC_API_KEY="your-anthropic-api-key"
# OAuth login — MS365 (Azure AD App Registration → client ID + secret, redirect URI: {APP_URL}/api/v1/auth/oauth/ms365/callback)
MS365_CLIENT_ID=""
MS365_CLIENT_SECRET=""
MS365_TENANT_ID="common"
# OAuth login — Google (Google Cloud Console → OAuth 2.0 Client, redirect URI: {APP_URL}/api/v1/auth/oauth/google/callback)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Optional: public URL of this app — used to build clickable deep links in email notifications.
APP_URL="https://crm.example.com"
