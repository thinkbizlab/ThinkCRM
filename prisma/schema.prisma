  siteLat          Float?
  siteLng          Float?
  visitType        VisitType
  status           VisitStatus      @default(PLANNED)
  plannedAt        DateTime
  objective        String?
  checkInAt        DateTime?
  checkInLat       Float?
  checkInLng       Float?
  checkInDistanceM Float?
  checkInSelfie    String?
  checkInRoad        String?
  checkInSubdistrict String?
  checkInDistrict    String?
  checkInProvince    String?
  checkOutAt       DateTime?
  checkOutLat      Float?
  checkOutLng      Float?
  result           String?
  isDemo           Boolean          @default(false)
  createdByUserId  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
