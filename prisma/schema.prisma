// Prospect represents an unidentified site (e.g. a construction site a rep
// drove past) before it is linked to a real Customer. Visits can be created
// against a Prospect; once the Prospect is identified, its visits get
// re-pointed to the resolved Customer. Stays local even for federated tenants.
model Prospect {
  id               String          @id @default(cuid())
  tenantId         String
  status           ProspectStatus  @default(UNIDENTIFIED)
  displayName      String?
  siteLat          Float?
  siteLng          Float?
  siteAddress      String?
  contactName      String?
  contactPhone     String?
  notes            String?
  linkedCustomerId String?
  createdById      String
  updatedById      String?
  archivedAt       DateTime?
  isDemo           Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  linkedCustomer   Customer?       @relation("ProspectLinkedCustomer", fields: [linkedCustomerId], references: [id], onDelete: SetNull)
  createdBy        User            @relation("ProspectCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy        User?           @relation("ProspectUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  photos           ProspectPhoto[]
  visits           Visit[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, linkedCustomerId])
}

enum ProspectStatus {
  UNIDENTIFIED
  IDENTIFIED
  LINKED
  ARCHIVED
}

