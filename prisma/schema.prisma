// Announcement: tenant-admin broadcast that every user in the tenant sees as a
// modal until they click Accept. The modal disappears on ack and never returns
// for that user. AnnouncementAck rows are the read receipt log.
model Announcement {
  id              String            @id @default(cuid())
  tenantId        String
  title           String
  body            String
  // Empty array = broadcast to every active user. Non-empty = only users
  // whose role is in this list will see (and need to acknowledge) it.
  roles           UserRole[]        @default([])
  createdById     String?
  isDemo          Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User?             @relation("AnnouncementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  acknowledgments AnnouncementAck[]

  @@index([tenantId, createdAt])
}

model AnnouncementAck {
  id             String       @id @default(cuid())
  tenantId       String
  announcementId String
  userId         String
  acknowledgedAt DateTime     @default(now())
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation("AnnouncementAckUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([tenantId, userId])
  @@index([tenantId, announcementId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  tenantId  String
  userId    String
  deviceId  String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model UserDevice {
  id          String         @id @default(cuid())
  tenantId    String
  userId      String
  platform    DevicePlatform
  deviceToken String
  deviceName  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceToken])
  @@index([tenantId, userId])
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

enum CronRunStatus {
  RUNNING
  SUCCESS
  FAILURE
}

enum CronTriggerType {
  SCHEDULED
  MANUAL
}

// ── WebAuthn Passkeys ───────────────────────────────────────────────────────

model UserPasskey {
  id           String    @id @default(cuid())
  userId       String
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt    @default(0)
  transports   String[]
  deviceName   String    @default("Passkey")
  aaguid       String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── WebAuthn Challenges ─────────────────────────────────────────────────────

model WebAuthnChallenge {
  id        String   @id @default(cuid())
  challenge String   @unique
  userId    String?
  tenantId  String?
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ── Data Sync Framework ─────────────────────────────────────────────────────

model SyncApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  label      String
  keyHash    String    @unique
  keyPrefix  String
  scopes     String[]
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SyncExternalRef {
  id             String     @id @default(cuid())
  tenantId       String
  entityType     EntityType
  entityId       String
  externalId     String
  externalSource String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, entityType, externalId, externalSource])
  @@index([tenantId, entityType, entityId])
}
