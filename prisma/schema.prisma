generator client {
  provider        = "prisma-client-js"
  // postgresqlExtensions: lets us declare pg_trgm + btree_gin in the
  // datasource so `prisma db push` (used by CI) creates them before the
  // GIN trigram indexes on Customer try to use gin_trgm_ops / text_ops.
  // Production runs `prisma migrate deploy` which uses migration SQL
  // instead, but the migration also has CREATE EXTENSION IF NOT EXISTS
  // so both paths converge on the same state.
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pg_trgm, btree_gin]
}

model Tenant {
  id                          String                        @id @default(cuid())
  name                        String
  slug                        String                        @unique
  timezone                    String                        @default("Asia/Bangkok")
  isActive                    Boolean                       @default(true)
  deactivatedAt               DateTime?
  manageCustomersByApi        Boolean                       @default(false)
  manageItemsByApi            Boolean                       @default(false)
  managePaymentTermsByApi     Boolean                       @default(false)
  manageCustomerGroupsByApi   Boolean                       @default(false)
  staleProspectAlertDays      Int                           @default(14)
  // When non-null, this tenant's Customer master is read live from the MySQL
  // IntegrationSource at this id. We keep thin shadow rows in our DB so FKs
  // (Deal/Quotation/Visit → Customer) keep working; attribute reads hit the
  // tenant's MySQL on demand. See src/modules/federation/customer-federation.ts.
  customerFederationSourceId  String?
  customerFederationSource    IntegrationSource?            @relation("CustomerFederationSource", fields: [customerFederationSourceId], references: [id], onDelete: SetNull)
  stripeCustomerId            String?
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @updatedAt
  users                       User[]
  subscriptions               Subscription[]
  subscriptionProrationEvents SubscriptionProrationEvent[]
  invoices                    TenantInvoice[]
  storageQuotas               TenantStorageQuota[]
  storageUsageDaily           TenantStorageUsageDaily[]
  paymentTerms                PaymentTerm[]
  customerGroups              CustomerGroup[]
  customers                   Customer[]
  prospects                   Prospect[]
  items                       Item[]
  deals                       Deal[]
  quotations                  Quotation[]
  visits                      Visit[]
  integrations                IntegrationSource[]
  integrationCredentials      TenantIntegrationCredential[]
  integrationLogs             IntegrationExecutionLog[]
  integrationSyncJobs         IntegrationSyncJob[]
  teams                       Team[]
  branding                    TenantBranding?
  taxConfig                   TenantTaxConfig?
  visitConfig                 TenantVisitConfig?
  kpiTargets                  SalesKpiTarget[]
  aiAnalysisRuns              AiAnalysisRun[]
  aiVisitRecommendationRuns   AiVisitRecommendationRun[]
  voiceNoteJobs               VoiceNoteJob[]
  notificationChannels        TeamNotificationChannel[]
  customFieldDefinitions      CustomFieldDefinition[]
  quotationFormConfig         QuotationFormConfig?
  entityChangelogs            EntityChangelog[]
  customerDuplicateCandidates CustomerDuplicateCandidate[]
  userDelegations             UserDelegation[]
  roleChainEntries            TenantRoleChain[]
  customDomain                TenantCustomDomain?
  cronJobConfigs              CronJobConfig[]
  cronJobRuns                 CronJobRun[]
  userInvites                 UserInvite[]
  auditLogs                   AuditLog[]
  stripeWebhookDeliveries     StripeWebhookDelivery[]
  syncApiKeys                 SyncApiKey[]
  syncExternalRefs            SyncExternalRef[]
  transformTemplates          TransformTemplate[]
  aiUsageEvents               AiUsageEvent[]
  visitCoVisitors             VisitCoVisitor[]
  competencyTemplates         CompetencyTemplate[]
  announcements               Announcement[]
  announcementAcks            AnnouncementAck[]
  clientRequestLogs           ClientRequestLog[]
  syncDiscardEvents           SyncDiscardEvent[]
}

model User {
  id                        String                     @id @default(cuid())
  tenantId                  String
  email                     String
  passwordHash              String                     @default("")
  fullName                  String
  role                      UserRole
  isActive                  Boolean                    @default(true)
  mustResetPassword         Boolean                    @default(false)
  emailVerified             Boolean                    @default(false)
  emailVerifyToken          String?                    @unique
  emailVerifyExpiresAt      DateTime?
  managerUserId             String?
  teamId                    String?
  notifPrefs                Json?
  avatarUrl                 String?
  isDemo                    Boolean                    @default(false)
  lastSeenAt                DateTime?
  externalAccounts          UserExternalAccount[]
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  tenant                    Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manager                   User?                      @relation("UserManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  team                      Team?                      @relation(fields: [teamId], references: [id], onDelete: SetNull)
  reports                   User[]                     @relation("UserManager")
  directedTeams             Team[]                     @relation("TeamDirector")
  dealUpdates               DealProgressUpdate[]
  integrationLogs           IntegrationExecutionLog[]
  ownedDeals                Deal[]                     @relation("DealOwner")
  ownedVisits               Visit[]                    @relation("VisitRep")
  ownedCustomers            Customer[]                 @relation("CustomerOwner")
  createdCustomers          Customer[]                 @relation("CustomerCreatedBy")
  draftedCustomers          Customer[]                 @relation("CustomerDraftCreatedBy")
  createdDeals              Deal[]                     @relation("DealCreatedBy")
  createdVisits             Visit[]                    @relation("VisitCreatedBy")
  createdProspects          Prospect[]                 @relation("ProspectCreatedBy")
  updatedProspects          Prospect[]                 @relation("ProspectUpdatedBy")
  uploadedProspectPhotos    ProspectPhoto[]            @relation("ProspectPhotoUploadedBy")
  delegatedAs               UserDelegation[]           @relation("UserDelegationDelegate")
  principalFor              UserDelegation[]           @relation("UserDelegationPrincipal")
  voiceNoteRequested        VoiceNoteJob[]             @relation("VoiceRequestedBy")
  voiceNoteConfirmed        VoiceNoteTranscript[]      @relation("VoiceConfirmedBy")
  aiVisitRecommendationRuns AiVisitRecommendationRun[] @relation("AiVisitRecommendationRunRep")
  entityChangelogs          EntityChangelog[]          @relation("EntityChangelogChangedBy")
  devices                   UserDevice[]
  passkeys                  UserPasskey[]
  aiUsageEvents             AiUsageEvent[]
  coVisitorVisits           VisitCoVisitor[]           @relation("VisitCoVisitorUser")
  releasedCoVisitorEvals    VisitCoVisitor[]           @relation("VisitCoVisitorReleasedBy")
  notificationState         UserNotificationState?
  createdAnnouncements      Announcement[]             @relation("AnnouncementCreatedBy")
  announcementAcks          AnnouncementAck[]          @relation("AnnouncementAckUser")

  @@unique([tenantId, email])
  @@index([tenantId, isActive, role])
  @@index([tenantId, lastSeenAt])
}

// Per-user "I last opened the bell at <ts>" marker. Powers the unread-dot
// on the notifications bell — items whose underlying timestamp is newer
// than `notifLastSeenAt` count as unread. Single row per user; updated
// only when the user opens the bell panel. See src/modules/notifications.
model UserNotificationState {
  userId          String    @id
  notifLastSeenAt DateTime?
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserDelegation {
  id              String   @id @default(cuid())
  tenantId        String
  delegateUserId  String
  principalUserId String
  startsAt        DateTime @default(now())
  endsAt          DateTime @default(dbgenerated("'9999-12-31 23:59:59'::timestamp"))
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  delegate        User     @relation("UserDelegationDelegate", fields: [delegateUserId], references: [id], onDelete: Cascade)
  principal       User     @relation("UserDelegationPrincipal", fields: [principalUserId], references: [id], onDelete: Cascade)

  @@unique([delegateUserId, principalUserId])
  @@index([tenantId, delegateUserId])
  @@index([tenantId, principalUserId])
}

model EntityChangelog {
  id          String     @id @default(cuid())
  tenantId    String
  entityType  EntityType
  entityId    String
  action      String
  beforeJson  Json?
  afterJson   Json?
  contextJson Json?
  changedById String?
  createdAt   DateTime   @default(now())
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  changedBy   User?      @relation("EntityChangelogChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId, createdAt])
}

model Subscription {
  id                   String                       @id @default(cuid())
  tenantId             String
  provider             BillingProvider
  pricingModel         PricingModel                 @default(FIXED_PER_USER)
  status               SubscriptionStatus
  seatPriceCents       Int
  seatCount            Int                          @default(1)
  currency             String                       @default("THB")
  paymentMethodRef     String?
  billingCycle         BillingCycle                 @default(MONTHLY)
  billingPeriodStart   DateTime                     @default(now())
  billingPeriodEnd     DateTime                     @default(now())
  externalCustomerId   String?
  stripeSubscriptionId String?                      @unique
  trialEndsAt          DateTime?
  planFeatures         Json?
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  tenant               Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prorationEvents      SubscriptionProrationEvent[]
}

model TenantStorageQuota {
  id                String   @id @default(cuid())
  tenantId          String
  includedBytes     BigInt   @default(1073741824)
  overagePricePerGb Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantStorageUsageDaily {
  id                     String   @id @default(cuid())
  tenantId               String
  usageDate              String
  totalBytes             BigInt
  overageBytes           BigInt
  estimatedOverageAmount Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, usageDate])
}

model SubscriptionProrationEvent {
  id                  String       @id @default(cuid())
  tenantId            String
  subscriptionId      String
  oldSeatCount        Int
  newSeatCount        Int
  seatDelta           Int
  daysRemaining       Int
  totalPeriodDays     Int
  proratedAmountCents Int
  effectiveAt         DateTime
  createdAt           DateTime     @default(now())
  tenant              Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription        Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model TenantInvoice {
  id                        String        @id @default(cuid())
  tenantId                  String
  invoiceMonth              String
  periodStart               String
  periodEnd                 String
  currency                  String
  seatsBaseCents            Int
  storageOverageCents       Int
  prorationAdjustmentsCents Int
  totalDueCents             Int
  status                    InvoiceStatus @default(DRAFT)
  finalizedAt               DateTime?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  tenant                    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, invoiceMonth])
}

model Team {
  id         String                    @id @default(cuid())
  tenantId   String
  teamName   String
  isActive   Boolean                   @default(true)
  isDemo     Boolean                   @default(false)
  directorId String?
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  tenant     Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  director   User?                     @relation("TeamDirector", fields: [directorId], references: [id], onDelete: SetNull)
  users      User[]
  channels   TeamNotificationChannel[]
}

model TeamNotificationChannel {
  id            String      @id @default(cuid())
  tenantId      String
  teamId        String
  channelType   ChannelType
  channelTarget String
  isEnabled     Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  team          Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model TenantIntegrationCredential {
  id              String              @id @default(cuid())
  tenantId        String
  platform        IntegrationPlatform
  clientIdRef     String?
  clientSecretRef String?
  apiKeyRef       String?
  webhookTokenRef String?
  status          SourceStatus        @default(DISABLED)
  lastTestedAt    DateTime?
  lastTestResult  String?
  lastTestStatus  ExecutionStatus?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, platform])
}

model TenantBranding {
  id                    String    @id @default(cuid())
  tenantId              String    @unique
  appName               String?
  logoUrl               String?
  faviconUrl            String?
  primaryColor          String    @default("#2563eb")
  secondaryColor        String    @default("#0f172a")
  accentGradientEnabled Boolean   @default(false)
  accentGradientColor   String    @default("#ec4899")
  accentGradientAngle   Int       @default(135)
  themeTokens           Json      @default("{}")
  themeMode             ThemeMode @default(LIGHT)
  loginTaglineHeadline  String?
  loginTaglineSubtext   String?
  loginHeroImageUrl     String?
  loginWelcomeMessage   String?
  loginFooterText       String?
  loginTermsUrl         String?
  loginPrivacyUrl       String?
  loginSupportEmail     String?
  loginShowSignup       Boolean   @default(true)
  loginShowGoogle       Boolean   @default(true)
  loginShowMicrosoft    Boolean   @default(true)
  loginShowPasskey      Boolean   @default(true)
  // Layout for the uploaded `loginHeroImageUrl`:
  //   BACKGROUND   — image fills the left hero panel (current behaviour)
  //   INLINE_LOGO  — image renders as a small logo above the wordmark/tagline,
  //                  panel keeps its solid background. Use when a tenant just
  //                  wants a compact branded mark, not a full-bleed photo.
  loginHeroLayout       String    @default("BACKGROUND")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantTaxConfig {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  vatEnabled     Boolean  @default(true)
  vatRatePercent Float    @default(7.0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantVisitConfig {
  id                      String   @id @default(cuid())
  tenantId                String   @unique
  checkInMaxDistanceM     Int      @default(1000)
  minVisitDurationMinutes Int      @default(15)
  // When false (default), a visit that has any checked-in co-visitor does NOT
  // count toward the rep's normal visit KPI — it counts only as the
  // co-visitor's supervisor KPI. Flip on if a tenant wants the rep to keep
  // visit credit even when supervised.
  coVisitCountsAsRepVisit Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  tenant                  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PaymentTerm {
  id           String      @id @default(cuid())
  tenantId     String
  code         String
  name         String
  dueDays      Int
  isActive     Boolean     @default(true)
  customFields Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotations   Quotation[]

  @@unique([tenantId, code])
}

model CustomerGroup {
  id           String     @id @default(cuid())
  tenantId     String
  code         String
  name         String
  description  String?
  isActive     Boolean    @default(true)
  isDemo       Boolean    @default(false)
  customFields Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers    Customer[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Customer {
  id                   String            @id @default(cuid())
  tenantId             String
  ownerId              String?
  customerCode         String?
  name                 String
  externalRef          String?
  customerType         CustomerType      @default(COMPANY)
  taxId                String?
  // Thai-style branch code (e.g. "00000" = HQ, "00001" = first branch).
  // Required whenever taxId is set so (taxId, branchCode) uniquely identifies
  // a billable entity. NULL only when taxId is NULL.
  branchCode           String?
  // Optional corporate-group link to another customer in the same tenant
  // (e.g. holding company → subsidiary). Independent of taxId/branchCode.
  parentCustomerId     String?
  customerGroupId      String?
  status               CustomerStatus    @default(ACTIVE)
  draftCreatedByUserId String?
  promotedAt           DateTime?
  siteLat              Float?
  siteLng              Float?
  customFields         Json?
  disabled             Boolean           @default(false)
  isDemo               Boolean           @default(false)
  createdByUserId      String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  tenant               Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerGroup        CustomerGroup?    @relation(fields: [customerGroupId], references: [id], onDelete: SetNull)
  owner                User?             @relation("CustomerOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdBy            User?             @relation("CustomerCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  draftCreatedBy       User?             @relation("CustomerDraftCreatedBy", fields: [draftCreatedByUserId], references: [id], onDelete: SetNull)
  parentCustomer       Customer?         @relation("CustomerHierarchy", fields: [parentCustomerId], references: [id], onDelete: SetNull)
  childCustomers       Customer[]        @relation("CustomerHierarchy")
  addresses            CustomerAddress[]
  contacts             CustomerContact[]
  deals                Deal[]
  visits               Visit[]
  quotations           Quotation[]
  linkedProspects      Prospect[]        @relation("ProspectLinkedCustomer")

  @@unique([tenantId, taxId, branchCode])
  @@unique([tenantId, externalRef])
  @@index([tenantId, ownerId])
  @@index([tenantId, customerCode])
  @@index([tenantId, customerGroupId])
  @@index([tenantId, name])
  @@index([tenantId, status])
  @@index([tenantId, parentCustomerId])
  // GIN trigram indexes — make `name ILIKE '%q%'` and `customerCode ILIKE
  // '%q%'` index-backed in /customers/search. Requires pg_trgm + btree_gin
  // extensions (created in 20260505000000_customer_search_trgm_indexes).
  // `tenantId` uses btree_gin's text_ops so the scalar column can sit in a
  // GIN index alongside the trigram column.
  @@index([tenantId(ops: raw("text_ops")), name(ops: raw("gin_trgm_ops"))], type: Gin, map: "Customer_tenant_name_trgm_idx")
  @@index([tenantId(ops: raw("text_ops")), customerCode(ops: raw("gin_trgm_ops"))], type: Gin, map: "Customer_tenant_customerCode_trgm_idx")
}

enum CustomerStatus {
  DRAFT
  ACTIVE
}

enum CustomerDuplicateSignal {
  TAX_ID
  PHONE
  EMAIL
  NAME_EXACT
  NAME_FUZZY
  AI
}

enum CustomerDuplicateStatus {
  OPEN
  DISMISSED
  MERGED
}

model CustomerDuplicateCandidate {
  id          String                  @id @default(cuid())
  tenantId    String
  customerAId String
  customerBId String
  signal      CustomerDuplicateSignal
  confidence  Float                   @default(1.0)
  reasonText  String?
  status      CustomerDuplicateStatus @default(OPEN)
  decidedById String?
  decidedAt   DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerAId, customerBId, signal])
  @@index([tenantId, status, createdAt])
}

model CustomerAddress {
  id                 String      @id @default(cuid())
  customerId         String
  addressLine1       String
  subDistrict        String?
  district           String?
  province           String?
  city               String?
  state              String?
  country            String?
  postalCode         String?
  latitude           Float?
  longitude          Float?
  isDefaultBilling   Boolean     @default(false)
  isDefaultShipping  Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  customer           Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  billingQuotations  Quotation[] @relation("QuotationBillingAddress")
  shippingQuotations Quotation[] @relation("QuotationShippingAddress")
}

model CustomerContact {
  id           String   @id @default(cuid())
  customerId   String
  name         String
  position     String
  tel          String?
  email        String?
  lineId       String?
  whatsapp     String?
  customFields Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Item {
  id           String          @id @default(cuid())
  tenantId     String
  itemCode     String
  name         String
  externalRef  String?
  unitPrice    Float
  isActive     Boolean         @default(true)
  isDemo       Boolean         @default(false)
  customFields Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quoteItems   QuotationItem[]

  @@unique([tenantId, itemCode])
  @@unique([tenantId, externalRef])
  @@index([tenantId, name])
}

model CustomFieldDefinition {
  id           String              @id @default(cuid())
  tenantId     String
  entityType   EntityType
  fieldKey     String
  label        String
  dataType     CustomFieldDataType
  isRequired   Boolean             @default(false)
  isActive     Boolean             @default(true)
  displayOrder Int                 @default(0)
  optionsJson  Json?
  placeholder  String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, entityType, fieldKey])
}

model DealStage {
  id                    String   @id @default(cuid())
  tenantId              String
  stageName             String
  stageOrder            Int
  isClosedWon           Boolean  @default(false)
  isClosedLost          Boolean  @default(false)
  isDefault             Boolean  @default(false)
  allowForwardMove      Boolean  @default(true)
  allowBackwardMove     Boolean  @default(false)
  allowStageSkip        Boolean  @default(false)
  allowedSourceStageIds Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deals                 Deal[]

  @@unique([tenantId, stageOrder])
}

model Deal {
  id              String               @id @default(cuid())
  tenantId        String
  ownerId         String
  dealNo          String
  dealName        String
  customerId      String
  stageId         String
  estimatedValue  Float
  followUpAt      DateTime
  closedAt        DateTime?
  status          DealStatus           @default(OPEN)
  lostNote        String?
  customFields    Json?
  isDemo          Boolean              @default(false)
  createdByUserId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner           User                 @relation("DealOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  createdBy       User?                @relation("DealCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  customer        Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  stage           DealStage            @relation(fields: [stageId], references: [id], onDelete: Restrict)
  progress        DealProgressUpdate[]
  quotations      Quotation[]
  visits          Visit[]

  @@unique([tenantId, dealNo])
  @@index([tenantId, ownerId, status, closedAt])
  @@index([tenantId, stageId])
  @@index([tenantId, followUpAt])
  @@index([tenantId, customerId])
}

model DealProgressUpdate {
  id             String   @id @default(cuid())
  dealId         String
  createdById    String
  note           String
  attachmentUrls Json?
  createdAt      DateTime @default(now())
  deal           Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
}

model Quotation {
  id                String           @id @default(cuid())
  tenantId          String
  dealId            String
  quotationNo       String
  customerId        String
  paymentTermId     String
  billingAddressId  String?
  shippingAddressId String?
  validTo           DateTime
  status            QuotationStatus  @default(DRAFT)
  subtotal          Float
  vatRate           Float            @default(7.0)
  vatAmount         Float
  grandTotal        Float
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deal              Deal             @relation(fields: [dealId], references: [id], onDelete: Cascade)
  customer          Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  paymentTerm       PaymentTerm      @relation(fields: [paymentTermId], references: [id], onDelete: Restrict)
  billingAddress    CustomerAddress? @relation("QuotationBillingAddress", fields: [billingAddressId], references: [id], onDelete: SetNull)
