// Mobile sync-queue discard event. When a rep manually discards a permanently
// failed offline action (4xx that exhausted retries), the client posts here so
// admins can answer "what classes of errors are landing in the failure bucket".
// Pruned by the data-retention cron after 90 days — enough to spot quarterly
// trends without growing unbounded.
model SyncDiscardEvent {
  id               String   @id @default(cuid())
  tenantId         String
  userId           String
  kind             String   // "visit_checkin" | "visit_checkout"
  visitId          String
  retryCount       Int
  lastError        String?  // truncated client-side to 500 chars
  queuedDurationMs Int      // createdAt → discardedAt span
  platform         String   // "IOS" | "ANDROID"
  createdAt        DateTime @default(now())

  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, kind, createdAt])
}

// Idempotency log for mobile clients. When the offline-sync queue replays a
// request (e.g. after a flaky LTE timeout that lost the response), the route
// looks up (tenantId, clientRequestId) and returns the cached response instead
// of mutating state again. Pruned by the data-retention cron after 24h — the
// offline queue's exponential backoff peaks at 1h, so 24h is comfortably above
// the longest possible retry window.
model ClientRequestLog {
  tenantId        String
  clientRequestId String
  userId          String
  route           String
  responseStatus  Int
  responseBody    Json
  createdAt       DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([tenantId, clientRequestId])
  @@index([createdAt])
}

/// Short-lived one-time exchange code that wraps a signed JWT.
/// Created by OAuth callbacks; consumed by POST /auth/oauth/exchange.
/// Prevents the JWT from appearing in server logs, browser history, or Referer headers.
model OAuthExchangeCode {
  code      String   @id
  jwt       String
  expiresAt DateTime

  @@index([expiresAt])
}

