model TenantCustomDomain {
  id                String             @id @default(cuid())
  tenantId          String             @unique
  domain            String             @unique
  verificationToken String
  status            CustomDomainStatus @default(PENDING)
  verifiedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum CustomDomainStatus {
  PENDING
  VERIFIED
  FAILED
}

model CronJobConfig {
  id          String          @id @default(cuid())
  tenantId    String
  jobKey      String
  cronExpr    String
  timezone    String          @default("Asia/Bangkok")
  isEnabled   Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runs        CronJobRun[]

  @@unique([tenantId, jobKey])
}

model CronJobRun {
  id          String          @id @default(cuid())
  tenantId    String
  jobKey      String
  status      CronRunStatus
  startedAt   DateTime        @default(now())
  completedAt DateTime?
  summary     String?
  triggeredBy CronTriggerType @default(SCHEDULED)
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  config      CronJobConfig   @relation(fields: [tenantId, jobKey], references: [tenantId, jobKey], onDelete: Cascade)

  @@index([tenantId, jobKey, startedAt])
}

model OAuthState {
  state      String   @id
  tenantSlug String
  userId     String?
  expiresAt  DateTime

  @@index([expiresAt])
}

/// Short-lived one-time exchange code that wraps a signed JWT.
/// Created by OAuth callbacks; consumed by POST /auth/oauth/exchange.
/// Prevents the JWT from appearing in server logs, browser history, or Referer headers.
model OAuthExchangeCode {
  code      String   @id
  jwt       String
  expiresAt DateTime

  @@index([expiresAt])
}

model PasswordResetToken {
  token     String    @id
  tenantId  String
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([expiresAt])
}

model UserInvite {
  id         String    @id @default(cuid())
  tenantId   String
  email      String
  role       UserRole  @default(REP)
  teamId     String?
  invitedById String?
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([tenantId, email])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String
  detail    Json?
  ipAddress String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, action])
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  tenantId  String
  userId    String
  deviceId  String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model UserDevice {
  id          String         @id @default(cuid())
  tenantId    String
  userId      String
  platform    DevicePlatform
  deviceToken String
  deviceName  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceToken])
  @@index([tenantId, userId])
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

enum CronRunStatus {
  RUNNING
  SUCCESS
  FAILURE
}

enum CronTriggerType {
  SCHEDULED
  MANUAL
}

// ── WebAuthn Passkeys ───────────────────────────────────────────────────────

model UserPasskey {
  id               String   @id @default(cuid())
  userId           String
  credentialId     String   @unique
  publicKey        Bytes
  counter          BigInt   @default(0)
  transports       String[]
  deviceName       String   @default("Passkey")
  aaguid           String?
  createdAt        DateTime @default(now())
  lastUsedAt       DateTime?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── WebAuthn Challenges ─────────────────────────────────────────────────────

model WebAuthnChallenge {
  id        String   @id @default(cuid())
  challenge String   @unique
  userId    String?
  tenantId  String?
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ── Data Sync Framework ─────────────────────────────────────────────────────

model SyncApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  label       String
  keyHash     String    @unique
  keyPrefix   String
  scopes      String[]
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SyncExternalRef {
  id             String   @id @default(cuid())
  tenantId       String
  entityType     EntityType
  entityId       String
  externalId     String
  externalSource String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, entityType, externalId, externalSource])
  @@index([tenantId, entityType, entityId])
}

